# =============================================================================
# Gemek Premium — Environment Variables Template
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to source control.
# =============================================================================

# --- PostgreSQL ---
DB_USER=gemek
DB_PASSWORD=CHANGE_ME_db_password
DB_URL=jdbc:postgresql://postgres:5432/gemek

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- JWT ---
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# --- MinIO ---
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET=gemek
MINIO_ENDPOINT=http://minio:9000

# --- Firebase Cloud Messaging ---
# Set to true and provide a service account JSON file path to enable FCM push notifications.
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=prod
